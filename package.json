{
  "name": "code-trae",
  "version": "1.0.0",
  "description": "小学生学习追踪系统",
  "main": "backend/app.js",
  "scripts": {
    "start": "NODE_OPTIONS='--no-deprecation' node backend/app.js",
    "dev": "NODE_OPTIONS='--no-deprecation' nodemon backend/app.js",
    "test": "jest --coverage --config=backend/jest.config.js --rootDir=backend",
    "test:unit": "jest --config=backend/jest.config.js --rootDir=backend --testMatch='**/__tests__/**/*.unit.test.js'",
    "test:integration": "jest --config=backend/jest.config.js --rootDir=backend --testMatch='**/__tests__/**/*.integration.test.js'",
    "test:e2e": "jest --config=backend/jest.config.js --rootDir=backend --testMatch='**/__tests__/**/*.e2e.test.js'",
    "test:nocoverage": "npm run test:family-regression && npm run test:legacy-regression",
    "test:family-regression": "jest --config=backend/jest.config.js --coverage=false --selectProjects family-common user-service homework-service progress-service resource-family analytics-family analytics-attachments notification-family --runInBand",
    "test:family-flow:integration": "jest --config=backend/tests/task11/jest.config.js --runInBand",
    "test:family-flow:e2e": "playwright test --project=chromium",
    "test:task11": "npm run test:family-flow:integration && npm run test:family-flow:e2e",
    "test:task12:integration": "jest --config=backend/tests/task12/jest.config.js --runInBand",
    "test:task12:e2e": "playwright test --config=playwright.task12.config.js --project=chromium-task12",
    "test:task12": "npm run test:task12:integration && npm run test:task12:e2e",
    "test:family-security-scan": "bash scripts/test-family-security-scan.sh",
    "docs:family:check": "node scripts/check-family-docs.js",
    "release:family": "bash scripts/release-family-gate.sh",
    "release:family:task12": "bash scripts/release-family-gate.sh",
    "repair:family-relationships": "node backend/services/user-service/scripts/repairFamilyRelationships.js",
    "repair:family-relationships:check": "node backend/services/user-service/scripts/repairFamilyRelationships.js --check",
    "test:legacy-regression": "jest --config=backend/jest.config.js --coverage=false --selectProjects progress-legacy legacy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "k6:perf": "k6 run tests/performance/k6.config.js",
    "zap:security": "zap-cli --config-file tests/security/zap-config.yaml quick-scan --start-options '-cmd'",
    "clean:coverage": "./scripts/clean-coverage.sh",
    "remove:coverage-git": "./scripts/remove-coverage-from-git.sh",
    "find:coverage": "./scripts/find-coverage-files.sh",
    "docker:family": "docker compose -f docker-compose.family.yml up -d",
    "docker:family:down": "docker compose -f docker-compose.family.yml down",
    "docker:family:logs": "docker compose -f docker-compose.family.yml logs -f",
    "precommit": "npm run clean:coverage"
  },
  "dependencies": {
    "amqplib": "^0.10.8",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "chai": "^5.2.0",
    "chai-http": "^5.1.2",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.22.2",
    "express-http-proxy": "^1.6.3",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.4",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.2",
    "multer": "^1.4.5-lts.2",
    "password-validator": "^5.3.0",
    "pdf-lib": "1.17.1",
    "sanitize-html": "^2.15.0",
    "sharp": "^0.33.5",
    "sinon": "^20.0.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@playwright/test": "^1.61.1",
    "@types/k6": "^1.0.2",
    "eslint": "^9.8.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "k6": "^0.0.0",
    "mongodb-memory-server": "^10.1.4",
    "nock": "^14.0.4",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Your Name",
  "license": "MIT"
}
