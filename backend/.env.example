# JWT配置
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d
GATEWAY_IDENTITY_SECRET=replace-with-at-least-32-random-characters
INTERNAL_SERVICE_TOKEN=replace-with-an-independent-32-character-token
STAR_AWARD_TIMEOUT_MS=3000

# 数据库配置
MONGO_URI=mongodb://localhost:27017/learning-tracker
USER_SERVICE_MONGO_URI=mongodb://localhost:27017/learning-tracker-users
DATA_SERVICE_MONGO_URI=mongodb://localhost:27017/learning-tracker-data

# 服务端口配置
GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
DATA_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3007
HOMEWORK_SERVICE_PORT=3008
PROGRESS_SERVICE_PORT=3009
INTERACTION_SERVICE_PORT=3010
NOTIFICATION_SERVICE_PORT=3011
RESOURCE_SERVICE_PORT=3012

# 服务URL配置（用于网关代理）
USER_SERVICE_URL=http://localhost:3001
DATA_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3007
HOMEWORK_SERVICE_URL=http://localhost:3008
PROGRESS_SERVICE_URL=http://localhost:3009
INTERACTION_SERVICE_URL=http://localhost:3010
NOTIFICATION_SERVICE_URL=http://localhost:3011
RESOURCE_SERVICE_URL=http://localhost:3012

# 环境配置
NODE_ENV=development

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SENSITIVE_RATE_LIMIT_MAX_REQUESTS=20
